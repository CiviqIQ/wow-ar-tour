<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta http-equiv="refresh" content="0; url=/tour/" />
		<meta name="viewport" content="width=device-width" />
		<title>Redirecting…</title>
		<link rel="canonical" href="/tour/" />
	</head>
	<body>
		<p>Redirecting to <a href="/tour/">/tour/</a>…</p>
		<script>
			location.replace('/tour/');
		</script>
	</body>
</html>
