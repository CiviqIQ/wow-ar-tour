---
import BaseLayout from "../../../layouts/BaseLayout.astro";

const segments = [
  {
    id: "where_you_are",
    label: "Where you are",
    audioUrl: "/media/jacob/audio/segments/rosewood__where-you-are_v1.mp3",
    script:
      "If you travel southbound from the intersection of 12th Street and Chicon Street toward Huston-Tillotson University, you'll make it to the bottom of a short hill, maybe without knowing how unique of a position you're actually in.",
  },
  {
    id: "why_it_matters",
    label: "Why it matters",
    audioUrl: "/media/jacob/audio/segments/rosewood__why-it-matters_v1.mp3",
    script:
      "These grounds hold our challenges and our triumphs, where families found homes and where we reclaimed our freedom. This is a uniquely wondrous historical site in more ways than one.",
  },
  {
    id: "what_is_this_place",
    label: "What is this place",
    audioUrl: "/media/jacob/audio/segments/rosewood__rosewood-courts-what-it-is_v1.mp3",
    script:
      "On the corner of Rosewood and Chicon, Rosewood Courts, the first public housing project for African Americans in the United States, has been home to East Austin residents since 1939.",
  },
  {
    id: "key_fact",
    label: "Key fact",
    audioUrl: "/media/jacob/audio/segments/rosewood__new-deal-and-lbj_v1.mp3",
    script:
      "This community of homes was established as part of President Franklin D. Roosevelt's New Deal and also was lobbied for by then-Congressman Lyndon Baines Johnson, or LBJ.",
  },
  {
    id: "deeper_history",
    label: "Deeper history",
    audioUrl: "/media/jacob/audio/segments/rosewood__emancipation-park-juneteenth_v1.mp3",
    script:
      "The site of Rosewood Courts here was originally Emancipation Park, an extremely important social and recreational site where Juneteenth celebrations date all the way back to 1930. This is where Black families reunited to publicly celebrate our freedom and progress on our own terms.",
  },
  {
    id: "wrap",
    label: "Wrap",
    audioUrl: "/media/jacob/audio/segments/rosewood__thomas-j-white-and-wrap_v1.mp3",
    script:
      "This land was originally bought by a formerly enslaved man named Thomas J. White. Once he started the Emancipation Park Association back in 1905, he bought a five-acre tract right here within two years' time. So it's fitting that this place sits at the bottom of a hill, because the stories and significance run deep.",
  },
];
---

<BaseLayout
  title="Rosewood — Quick Answers (Jacob Fontaine)"
  description="Short, question-based audio segments for Rosewood Courts & Emancipation Park."
>
  <main class="wrap">
    <header class="head">
      <h1>Rosewood — Quick Answers</h1>
      <p class="sub">
        Prototype for in-tour context review. Tap a question to load audio; use the audio controls to play.
      </p>
      <p class="sub">
        <a class="link" href="/tour/stop/rosewood-courts">Back to Rosewood stop</a>
      </p>
    </header>

    <section class="grid">
      <div class="card">
        <h2 class="h2">Questions</h2>
        <div class="buttons">
          {segments.map((s) => (
            <button class="btn" data-audio={s.audioUrl} data-script={s.script}>
              {s.label}
            </button>
          ))}
        </div>

        <div class="panel">
          <div class="label">Jacob says</div>
          <div id="jacobSays" class="box">Select a question above.</div>
        </div>

        <audio id="player" controls preload="auto" style="width:100%"></audio>
        <p class="note">If Play is blocked, use the audio player controls directly.</p>
      </div>

      <div class="card">
        <h2 class="h2">Jacob (preview)</h2>
        <p class="note">Three.js preview with simple audio-driven mouth movement (staging review only).</p>
        <div class="viewer" aria-label="Jacob Fontaine preview">
          <canvas id="jacobCanvas" width="800" height="800"></canvas>
        </div>
        <p class="note">This is just for review context on staging (not 8th Wall).</p>
      </div>
    </section>
  </main>

  <script type="module">
    // NOTE: Inline module scripts in Astro static builds don't get bundled, so we use explicit ESM URLs.
    import * as THREE from 'https://unpkg.com/three@0.182.0/build/three.module.js';
    import { GLTFLoader } from 'https://unpkg.com/three@0.182.0/examples/jsm/loaders/GLTFLoader.js';

    const player = document.getElementById('player');
    const jacobSays = document.getElementById('jacobSays');
    const btns = Array.from(document.querySelectorAll('button[data-audio]'));

    // Surface module-load failures loudly.
    window.addEventListener('error', (e) => console.error('[Jacob preview] window error', e?.message || e, e));
    window.addEventListener('unhandledrejection', (e) => console.error('[Jacob preview] unhandledrejection', e?.reason || e));

    // --- Audio segment UI ---
    function nudgePlayer() {
      player.scrollIntoView({ behavior: 'smooth', block: 'center' });
      player.classList.add('flash');
      setTimeout(() => player.classList.remove('flash'), 900);
    }

    btns.forEach((b) => {
      b.addEventListener('click', () => {
        const audio = b.getAttribute('data-audio');
        const script = b.getAttribute('data-script');
        jacobSays.textContent = script || '';
        player.src = audio;
        player.load();
        nudgePlayer();
      });
    });

    // --- Three.js preview ---
    const canvas = document.getElementById('jacobCanvas');

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: false });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio || 1, 2));
    renderer.outputColorSpace = THREE.SRGBColorSpace;
    renderer.toneMapping = THREE.ACESFilmicToneMapping;
    renderer.toneMappingExposure = 0.9;

    const scene = new THREE.Scene();
    scene.background = new THREE.Color('#0b0b0c');

    const camera = new THREE.PerspectiveCamera(38, 1, 0.01, 100);

    function resize() {
      const parent = canvas.parentElement;
      const w = parent?.clientWidth || 420;
      const h = parent?.clientHeight || 420;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    window.addEventListener('resize', resize);

    // Softer lighting to avoid blown-out eyes.
    scene.add(new THREE.HemisphereLight(0xffffff, 0x1a1a1a, 0.95));
    const key = new THREE.DirectionalLight(0xffffff, 0.95);
    key.position.set(2, 3, 2);
    scene.add(key);
    const fill = new THREE.DirectionalLight(0xffffff, 0.25);
    fill.position.set(-2, 1.2, 2.0);
    scene.add(fill);

    const loader = new GLTFLoader();
    let root = null;
    let mouthTargets = [];
    let jawBone = null;

    function listMorphTargets(obj) {
      const found = new Set();
      obj.traverse((n) => {
        if (!n.isMesh) return;
        const dict = n.morphTargetDictionary;
        if (!dict) return;
        for (const k of Object.keys(dict)) found.add(k);
      });
      return Array.from(found).sort();
    }

    function findMouthTargets(obj) {
      const out = [];
      const preferredKeys = [
        'mouthOpen',
        'jawOpen',
        'JawOpen',
        'viseme_aa',
        'viseme_O',
        'viseme_oh',
      ];

      obj.traverse((n) => {
        if (!n.isMesh) return;
        const dict = n.morphTargetDictionary;
        const infl = n.morphTargetInfluences;
        if (!dict || !infl) return;

        // Try preferred keys first.
        for (const key of preferredKeys) {
          const idx = dict[key];
          if (typeof idx === 'number') out.push({ mesh: n, idx });
        }

        // Fallback: any morph name containing 'mouth' or 'jaw'
        for (const [key, idx] of Object.entries(dict)) {
          if (typeof idx !== 'number') continue;
          const k = String(key).toLowerCase();
          if (k.includes('mouth') || k.includes('jaw')) out.push({ mesh: n, idx });
        }
      });

      // Deduplicate by mesh+idx
      const dedup = new Map();
      for (const t of out) dedup.set(`${t.mesh.uuid}:${t.idx}`, t);
      return Array.from(dedup.values());
    }

    function findJawBone(obj) {
      let found = null;
      obj.traverse((n) => {
        if (found) return;
        if (!n.isBone) return;
        const name = (n.name || '').toLowerCase();
        if (name === 'jaw' || name.includes('jaw')) found = n;
      });
      return found;
    }

    function setMouth(v) {
      // Morph targets (preferred)
      if (mouthTargets.length) {
        for (const t of mouthTargets) t.mesh.morphTargetInfluences[t.idx] = v;
        return;
      }

      // Bone fallback (rotate jaw slightly)
      if (jawBone) {
        // Assume default is closed; rotate down around X a bit.
        jawBone.rotation.x = -0.35 * v;
      }
    }

    // Best-effort eye de-spook: if an eye material is pure white, darken it.
    function tweakMaterials(obj) {
      obj.traverse((n) => {
        if (!n.isMesh) return;
        const mats = Array.isArray(n.material) ? n.material : [n.material];
        for (const m of mats) {
          if (!m) continue;
          const name = (m.name || n.name || '').toLowerCase();
          if (name.includes('eye') || name.includes('cornea') || name.includes('iris')) {
            if (m.color) m.color.setRGB(0.75, 0.75, 0.75);
            if ('emissiveIntensity' in m) m.emissiveIntensity = 0.0;
            m.needsUpdate = true;
          }
        }
      });
    }

    loader.load(
      '/media/jacob/models/jacob-fontaine.glb',
      (gltf) => {
        root = gltf.scene;
        scene.add(root);
        tweakMaterials(root);
        const morphs = listMorphTargets(root);
        console.log('[Jacob preview] morph targets:', morphs);

        mouthTargets = findMouthTargets(root);
        jawBone = findJawBone(root);
        console.log('[Jacob preview] mouthTargets:', mouthTargets.map(t => ({ mesh: t.mesh.name, idx: t.idx })));
        console.log('[Jacob preview] jawBone:', jawBone?.name || null);

        if (!mouthTargets.length && !jawBone) {
          console.warn('[Jacob preview] No mouth/jaw targets found. Model likely lacks facial rig/blendshapes.');
        }

        // Auto-frame the model so we don't end up looking at empty space.
        // (model-viewer does this automatically; Three.js does not.)
        const bbox = new THREE.Box3().setFromObject(root);
        const size = bbox.getSize(new THREE.Vector3());
        const center = bbox.getCenter(new THREE.Vector3());
        console.log('[Jacob preview] bbox size:', size, 'center:', center);

        // Recenter model at origin for stable camera math.
        root.position.sub(center);

        // Pick a distance that fits the whole character, then we'll crop via camera target.
        const maxDim = Math.max(size.x, size.y, size.z);
        const fitDist = maxDim / (2 * Math.tan(THREE.MathUtils.degToRad(camera.fov * 0.5)));

        // Place camera slightly above center, in front.
        camera.position.set(0.15, size.y * 0.15, fitDist * 1.25);
        camera.lookAt(0, size.y * 0.15, 0);

        resize();
      },
      undefined,
      (err) => console.error('GLB load failed', err)
    );

    // --- Audio analyser (drives mouthOpen) ---
    let audioCtx = null;
    let analyser = null;
    let dataArray = null;

    function ensureAnalyser() {
      if (analyser) return;
      audioCtx = new (window.AudioContext || window.webkitAudioContext)();
      analyser = audioCtx.createAnalyser();
      analyser.fftSize = 1024;
      dataArray = new Uint8Array(analyser.fftSize);
      const src = audioCtx.createMediaElementSource(player);
      src.connect(analyser);
      analyser.connect(audioCtx.destination);
    }

    player?.addEventListener('play', () => {
      try {
        ensureAnalyser();
        audioCtx?.resume?.();
      } catch (e) {
        console.warn('Audio analyser init failed', e);
      }
    });

    function computeRms() {
      if (!analyser || !dataArray) return 0;
      analyser.getByteTimeDomainData(dataArray);
      let sum = 0;
      for (let i = 0; i < dataArray.length; i++) {
        const v = (dataArray[i] - 128) / 128;
        sum += v * v;
      }
      return Math.sqrt(sum / dataArray.length);
    }

    const t0 = performance.now();
    function tick(now) {
      requestAnimationFrame(tick);

      // Subtle camera motion so it feels alive.
      if (root) {
        const t = (now - t0) / 1000;
        // Keep the camera gently moving around a head/shoulders target.
        const baseZ = camera.position.z || 1.0;
        camera.position.x = Math.sin(t * 0.30) * 0.10;
        camera.position.z = baseZ + Math.cos(t * 0.30) * 0.02;
        camera.position.y = (camera.position.y || 0.5) + Math.sin(t * 0.18) * 0.01;
        camera.lookAt(0, (camera.position.y || 0.5) - 0.05, 0);
      }

      // Drive mouth when audio plays.
      if (player && !player.paused && !player.ended) {
        const rms = computeRms();
        const mouth = Math.max(0, Math.min(1, rms * 4.0));
        setMouth(mouth);
      } else {
        setMouth(0);
      }

      renderer.render(scene, camera);
    }

    resize();
    requestAnimationFrame(tick);
  </script>

  <style>
    .wrap { max-width: 1100px; margin: 0 auto; padding: 24px 16px 48px; }
    .head h1 { margin: 0 0 6px; }
    .sub { margin: 0 0 10px; color: rgba(255,255,255,.75); }
    .link { color: #fff; }

    .grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
    @media (max-width: 900px) { .grid { grid-template-columns: 1fr; } }

    .card { background: rgba(255,255,255,.06); border: 1px solid rgba(255,255,255,.12); border-radius: 14px; padding: 14px; }
    .note { margin: 10px 0 0; color: rgba(255,255,255,.7); font-size: 14px; }
    .h2 { margin: 0 0 10px; font-size: 16px; }

    .buttons { display: grid; grid-template-columns: 1fr; gap: 10px; }
    @media (min-width: 680px) { .buttons { grid-template-columns: 1fr 1fr; } }

    .btn { padding: 10px 12px; border-radius: 10px; border: 1px solid rgba(255,255,255,.18); background: rgba(255,255,255,.10); color: #fff; cursor: pointer; text-align: left; }

    .panel { margin: 10px 0 12px; }
    .label { font-size: 12px; color: rgba(255,255,255,.65); margin-bottom: 6px; }
    .box { background: rgba(0,0,0,.25); border: 1px solid rgba(255,255,255,.10); border-radius: 10px; padding: 10px; min-height: 72px; }

    .viewer { width: 100%; height: 420px; background: #0b0b0c; border-radius: 12px; overflow: hidden; border: 1px solid rgba(255,255,255,.10); }
    .viewer canvas { width: 100%; height: 100%; display: block; }

    audio.flash { outline: 2px solid rgba(215, 180, 106, .9); outline-offset: 3px; border-radius: 10px; }
  </style>
</BaseLayout>
