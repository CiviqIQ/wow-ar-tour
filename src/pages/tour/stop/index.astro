---
// This route exists only to handle accidental visits to /tour/stop/
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';

const title = 'Choose a stop | WOW AR Tour';
---

<BaseLayout title={title}>
  <SiteHeader />
  <section class="section">
    <div class="container">
      <h1 class="h1">Choose a stop</h1>
      <p class="p">This page requires a stop id. Go back to the tour list:</p>
      <p><a class="btn btn--primary" href="/tour/">Back to all stops</a></p>
    </div>
  </section>
</BaseLayout>
