---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SiteHeader from '../../../components/SiteHeader.astro';
import data from '../../../data/stops.json';

export function getStaticPaths() {
  return data.stops.map((s) => ({ params: { stop: s.id } }));
}

const { stop: stopId } = Astro.params;
const stopIndex = data.stops.findIndex((s) => s.id === stopId);
const stop = stopIndex >= 0 ? data.stops[stopIndex] : undefined;
const prev = stopIndex > 0 ? data.stops[stopIndex - 1] : null;
const next = stopIndex >= 0 && stopIndex < data.stops.length - 1 ? data.stops[stopIndex + 1] : null;

const title = stop ? `${stop.name} | ${data.tourName}` : `Stop not found | ${data.tourName}`;
const description = stop ? `Launch the AR story for ${stop.name}.` : 'Stop not found.';
---

<BaseLayout title={title} description={description}>
  <SiteHeader />

  <section class="section">
    <div class="container">
      <p><a href="/tour/" class="small" data-evt="nav_all" data-stop={stopId}>← Back to all stops</a></p>

      {stop ? (
        <>
          <span class="badge">Stop</span>
          <h1 class="h1">{stop.name}</h1>
          <p class="p">{stop.address}</p>

          <div class="card" style="margin-top:18px">
            <div class="card__body">
              <h2 class="h2">Launch AR experience</h2>
              <p class="p">This opens the current 8th Wall experience in a new tab. After you finish, return here for the next stop.</p>

              {stop.arUrl ? (
                <a class="btn btn--primary" href={stop.arUrl} target="_blank" rel="noreferrer" data-evt="launch_ar" data-stop={stop.id}>Launch AR</a>
              ) : (
                <p class="p"><strong>AR link missing.</strong> Add the 8th.io/8thwall link for this stop in <code>src/data/stops.json</code>.</p>
              )}

              <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:12px">
                {stop.mapUrl ? <a class="btn" href={stop.mapUrl} target="_blank" rel="noreferrer" data-evt="map_click" data-stop={stop.id}>Map It</a> : null}
                <a class="btn" href="https://whatoncewas.org/ar-tour-our-stories-our-streets/" target="_blank" rel="noreferrer" data-evt="orig_page" data-stop={stop.id}>Original tour page</a>
              </div>

              <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:18px">
                {prev ? <a class="btn" href={`/tour/stop/${prev.id}/`} data-evt="nav_prev" data-stop={stop.id}>← Prev</a> : null}
                {next ? <a class="btn" href={`/tour/stop/${next.id}/`} data-evt="nav_next" data-stop={stop.id}>Next →</a> : null}
                <a class="btn" href="/tour/" data-evt="nav_all" data-stop={stop.id}>All stops</a>
              </div>

              <div style="display:flex;gap:10px;flex-wrap:wrap;margin-top:14px">
                <button class="btn" type="button" data-copylink data-evt="copy_link" data-stop={stop.id}>Copy link</button>
                <a class="btn" href={`/tour/stop/${stop.id}/`} target="_blank" rel="noreferrer" data-evt="share_open" data-stop={stop.id}>Open in new tab</a>
                <button class="btn" type="button" data-reportissue data-evt="report_issue" data-stop={stop.id}>Report issue</button>
              </div>

              <hr style="border:0;border-top:1px solid rgba(255,255,255,.12);margin:18px 0" />
              <p class="small">Having trouble? Use a modern mobile browser (Safari/Chrome) and enable camera permissions.</p>
            </div>
          </div>
        </>
      ) : (
        <>
          <h1 class="h1">Stop not found</h1>
          <p class="p">We couldn’t find a stop with id: <code>{stopId}</code></p>
          <p class="p"><a href="/tour/">Return to all stops</a></p>
        </>
      )}
    </div>
  </section>

<script>
  (() => {
    // Lightweight analytics hooks.
    // If GA4/gtag is later installed, this will feed it via dataLayer.
    const stopId = document.querySelector('[data-stop]')?.getAttribute('data-stop') || '';

    const emit = (eventName, extra = {}) => {
      const payload = { event: eventName, stop_id: stopId, ...extra };
      if (typeof window.gtag === 'function') {
        window.gtag('event', eventName, payload);
      } else if (window.dataLayer && Array.isArray(window.dataLayer)) {
        window.dataLayer.push(payload);
      } else {
        console.log('[WOW analytics]', payload);
      }
    };

    emit('stop_view');

    document.addEventListener('click', async (e) => {
      const a = e.target.closest('[data-evt]');
      if (!a) return;

      // copy link helper
      const copyBtn = e.target.closest('[data-copylink]');
      if (copyBtn) {
        try {
          await navigator.clipboard.writeText(location.href);
          emit('copy_link_success');
          copyBtn.textContent = 'Copied!';
          setTimeout(() => (copyBtn.textContent = 'Copy link'), 1200);
        } catch {
          emit('copy_link_failed');
          window.prompt('Copy this link:', location.href);
        }
        return;
      }

      // report issue helper
      const reportBtn = e.target.closest('[data-reportissue]');
      if (reportBtn) {
        const stop = reportBtn.getAttribute('data-stop') || '';
        const subject = encodeURIComponent(`WOW AR Tour issue: ${stop}`);
        const body = encodeURIComponent(`Stop: ${stop}\nURL: ${location.href}\n\nDescribe the issue:`);
        location.href = `mailto:carl@civiciq.consulting?subject=${subject}&body=${body}`;
        emit('report_issue_opened');
        return;
      }

      emit(a.getAttribute('data-evt'));
    });
  })();
</script>

</BaseLayout>
